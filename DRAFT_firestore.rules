rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 1. Primitive Definition Helpers
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    // Auth token checks
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // RBAC lookups
    function getRole() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function isAdmin() { return isSignedIn() && getRole() == 'admin'; }
    function isRider() { return isSignedIn() && getRole() == 'rider'; }

    // 2. Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'status']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['admin', 'rider', 'support', 'customer'] &&
             data.status in ['pending', 'verified', 'rejected', 'active', 'inactive'];
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['orderId', 'type', 'status', 'pickup', 'dropoff']) &&
             isValidId(data.orderId) &&
             data.type in ['standard', 'prime', 'emergency'] &&
             data.status in ['placed', 'assigned', 'picked_up', 'delivered', 'cancelled'];
    }

    // 3. Collection Rules
    
    // Users Profile
    match /users/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming()) && isOwner(userId);
      allow update: if isSignedIn() && isOwner(userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'phoneNumber', 'updatedAt']) &&
                      incoming().updatedAt == request.time;
    }

    // Rider Specific Profiles
    match /riders/{riderId} {
      allow get: if isSignedIn() && (isOwner(riderId) || isAdmin());
      allow list: if isAdmin();
      allow create: if isAdmin(); // Admin initiates rider verification
      allow update: if (isOwner(riderId) || isAdmin()) && 
                      (isAdmin() || incoming().diff(existing()).affectedKeys().hasOnly(['isOnline', 'currentLocation', 'updatedAt']));
    }

    // Orders System
    match /orders/{orderId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.riderId == request.auth.uid || resource.data.customerId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && isValidOrder(incoming());
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isRider() && existing().riderId == request.auth.uid && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
    }
    
    // Transactions / Wallet
    match /transactions/{txId} {
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin(); // Only system can write transactions
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && isOwner(resource.data.userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['isRead']);
      allow create, delete: if isAdmin();
    }
  }
}
